{
  "git": {
    "deploymentEnabled": {
      "dependabot/*": false,
      "dependabot/**": false
    }
  },
  "functions": {
    "app/api/**/*": {
      "maxDuration": 30,
      "regions": ["bom1"]
    }
  },
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/portfolio-snapshot",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/ingest-liquidations",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/whale-trades",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/telegram-daily",
      "schedule": "0 8 * * *"
    }
  ]
}
