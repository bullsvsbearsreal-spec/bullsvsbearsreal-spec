{
  "functions": {
    "app/api/**/*": {
      "maxDuration": 30,
      "regions": ["bom1"]
    }
  },
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/portfolio-snapshot",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/ingest-liquidations",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/arbitrage-alerts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/news-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/calendar-alerts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/telegram-reports",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/telegram-weekly",
      "schedule": "0 10 * * 0"
    }
  ]
}
