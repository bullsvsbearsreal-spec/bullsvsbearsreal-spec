# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# NextAuth
AUTH_SECRET=""  # Generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# OAuth (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_DISCORD_ID=
# AUTH_DISCORD_SECRET=

# Resend (email service)
RESEND_API_KEY=""

# APIs
CMC_API_KEY=""  # CoinMarketCap — required for /coin pages, top-movers, dominance, search
# COINMARKETCAL_API_KEY=  # Required for /economic-calendar (crypto events)
# CRYPTOPANIC_API_KEY=  # Required for /news (optional, has free fallback)
# ETHERSCAN_API_KEY=  # Required for /wallet on-chain lookups
# ARBITRUM_RPC_URL=  # Required for gTrade reader (positions on Arbitrum)
# PROXY_URL=  # Cloudflare Worker proxy for blocked exchanges
# ANTHROPIC_API_KEY=  # For AI chat feature (web /chat page)

# Cloudflare Turnstile (signup + forgot-password captcha)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Encryption for user-supplied exchange API keys (REQUIRED for the
# connected-exchanges feature to work at all). Generate with:
#   openssl rand -hex 32
# EXCHANGE_KEY_ENCRYPTION_KEY=

# Telegram Bot (optional) — single bot @InfoHubRadarBot, alerts only
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Public canonical origin (used for absolute URLs in cron handlers,
# email templates, OG images, etc). Without this, server-side fetch
# back to /api/* can break in containerized environments.
NEXT_PUBLIC_BASE_URL="https://info-hub.io"

# Web Push (browser notifications). Generate with:
#   npx web-push generate-vapid-keys
# The PUBLIC key MUST use the NEXT_PUBLIC_ prefix so it's inlined into
# the browser bundle for subscribe(). Server reads the same name.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT="mailto:noreply@info-hub.io"

# Cron (systemd timers on the droplet hit /api/cron/* with this token)
# CRON_SECRET=

# Sentry (errors)
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Blob (avatar uploads — token still works post-Vercel migration)
# BLOB_READ_WRITE_TOKEN=

# Twitter API (auto-tweet on big funding flips — Basic plan ~$100/mo)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# AUTO_TWEET_DRY_RUN=1  # 1 = dry-run only, don't actually post

# Admin (seeds the admin role on bootstrap + protects /api/admin/*)
# ADMIN_EMAIL=team@info-hub.io
# ADMIN_API_KEY=  # Optional separate key for /api/admin/monitoring/*

# Nitter (twitter scraping fallback — kept as a list for round-robin)
# NITTER_INSTANCES=https://nitter.example.com,https://nitter2.example.com
